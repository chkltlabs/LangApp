# Host Ollama (macOS Docker Desktop: default works). Linux: ensure Ollama listens on 0.0.0.0 or use compose override.
OLLAMA_HOST=http://host.docker.internal:11434

# Tutoring / chat default model (see plan: qwen2.5:14b is a good M1 Max default)
LLM_MODEL=qwen2.5:14b
# Optional: smaller model for voice loop, larger for exercises (backend uses FAST when set for /voice flow)
LLM_MODEL_FAST=qwen2.5:7b
LLM_MODEL_STRONG=qwen2.5:32b

LANG_TARGET=Spanish
LANG_UI=English
CEFR_LEVEL=A2
# Optional BCP 47 locale for word segmentation / tooltips (default: derived from TTS_VOICE_TARGET, e.g. es-ES)
# LANG_TARGET_LOCALE=es-ES

# Piper voice keys (must match files in TTS container /voices)
TTS_VOICE_TARGET=es_ES-davefx-medium
TTS_VOICE_UI=en_US-lessac-medium

# Optional: protect API if exposed beyond localhost (leave empty for dev)
API_KEY=

# Whisper model size for STT container: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
